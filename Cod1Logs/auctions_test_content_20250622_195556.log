import request from 'supertest';
import app from '@root/index';
import { v4 as uuidv4 } from 'uuid';

describe('Auction API (Cod1)', () => {
  const auctionId: string = 'test-auction-id';

  it('GET /api/auctions/:auctionId returns auction item', async () => {
    const res = await request(app).get(`/api/auctions/${auctionId}`);
    expect(res.status).toBe(200);
    expect(res.body).toHaveProperty('id', auctionId);
  });

  it('POST /api/auctions/:auctionId/bids fails with invalid bid', async () => {
    const res = await request(app)
      .post(`/api/auctions/${auctionId}/bids`)
      .send({ amount: -100 });
    expect(res.status).toBe(400);
    expect(res.body).toHaveProperty('message');
  });

  it('POST /api/auctions/:auctionId/bids succeeds with valid bid', async () => {
    const res = await request(app)
      .post(`/api/auctions/${auctionId}/bids`)
      .send({ amount: 1000 });
    expect([200, 201]).toContain(res.status);
    expect(res.body).toHaveProperty('message');
  });
});

