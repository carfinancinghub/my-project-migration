import { EscrowService, BadRequestError, AuthorizationError } from '@services/escrow/escrow.service';
import { Escrow } from '@models/Escrow';
import { logger } from '@utils/logger';

describe('EscrowService', () => {
  let escrowService: EscrowService;

  beforeEach(() => {
    escrowService = new EscrowService();
    jest.clearAllMocks();
  });

  it('should create transaction successfully', async () => {
    const data = { vehicle: { vin: 'vin123', price: 10000 }, user: 'u1' };
    const mockTransaction = { _id: 'tx1', status: 'pending', user: 'u1', vehicle: { vin: 'vin123', price: 10000 } };
    jest.spyOn(Escrow, 'create').mockResolvedValueOnce(mockTransaction as any);
    const result = await escrowService.createTransaction(data);
    expect(result).toEqual(mockTransaction);
    expect(logger.info).toHaveBeenCalledWith(expect.stringContaining('Created escrow transaction'));
  });

  it('should fail for invalid transaction data', async () => {
    const data = { vehicle: { vin: '', price: 0 }, user: 'u1' };
    await expect(escrowService.createTransaction(data)).rejects.toThrow(BadRequestError);
    expect(logger.error).toHaveBeenCalledWith(expect.stringContaining('Invalid transaction data'));
  });

  it('should get transaction by ID', async () => {
    const mockTransaction = { _id: 'tx1', status: 'pending', user: 'u1', vehicle: { vin: 'vin123', price: 10000 } };
    jest.spyOn(Escrow, 'findById').mockResolvedValueOnce(mockTransaction as any);
    const result = await escrowService.getTransactionById('tx1', 'u1');
    expect(result).toEqual(mockTransaction);
    expect(logger.info).toHaveBeenCalledWith(expect.stringContaining('Retrieved transaction'));
  });

  it('should fail for unauthorized access', async () => {
    const mockTransaction = { _id: 'tx1', status: 'pending', user: 'u1', vehicle: { vin: 'vin123', price: 10000 } };
    jest.spyOn(Escrow, 'findById').mockResolvedValueOnce(mockTransaction as any);
    await expect(escrowService.getTransactionById('tx1', 'u3')).rejects.toThrow(AuthorizationError);
    expect(logger.error).toHaveBeenCalledWith(expect.stringContaining('Unauthorized access'));
  });

  it('should update condition successfully', async () => {
    const mockTransaction = { _id: 'tx1', status: 'pending', user: 'u1', vehicle: { vin: 'vin123', price: 10000 }, condition: '', save: jest.fn().mockResolvedValueOnce({}) };
    jest.spyOn(Escrow, 'findById').mockResolvedValueOnce(mockTransaction as any);
    const result = await escrowService.updateCondition('tx1', 'u1', 'good');
    expect(result.condition).toBe('good');
    expect(mockTransaction.save).toHaveBeenCalled();
    expect(logger.info).toHaveBeenCalledWith(expect.stringContaining('Updated condition'));
  });

  it('should fail to update condition for unauthorized user', async () => {
    const mockTransaction = { _id: 'tx1', status: 'pending', user: 'u1', vehicle: { vin: 'vin123', price: 10000 }, condition: '', save: jest.fn().mockResolvedValueOnce({}) };
    jest.spyOn(Escrow, 'findById').mockResolvedValueOnce(mockTransaction as any);
    await expect(escrowService.updateCondition('tx1', 'u3', 'good')).rejects.toThrow(AuthorizationError);
    expect(logger.error).toHaveBeenCalledWith(expect.stringContaining('Unauthorized to update condition'));
  });
});
